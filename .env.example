# Stripe API keys — get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — shown by `stripe listen` or in the Dashboard webhook settings
STRIPE_WEBHOOK_SECRET=whsec_...

# Local server config
PORT=8000
LOG_LEVEL=info

# SQLite DB file (created automatically if missing)
DB_PATH=./stripe_integration.db
